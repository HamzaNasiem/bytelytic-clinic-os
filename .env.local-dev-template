# ================================================================
# LOCAL DEV — Copy this to .env and fill in your real values
# Server starts with just Supabase filled. Other APIs only needed
# when you test that specific feature (calls, SMS, calendar).
# ================================================================

# Server
PORT=3000
NODE_ENV=development

# ── SUPABASE (required to start) ────────────────────────────────
# Get from: supabase.com → your project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_ROLE_KEY
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY

# ── RETELL AI (only needed for voice calls) ──────────────────────
# Get from: retell.ai → API Keys
RETELL_API_KEY=key_placeholder_get_from_retell
RETELL_WEBHOOK_SECRET=placeholder_set_after_you_configure_retell_webhook

# ── TWILIO (only needed for SMS) ─────────────────────────────────
# Get from: console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACplaceholder_get_from_twilio
TWILIO_AUTH_TOKEN=placeholder_get_from_twilio
TWILIO_DEFAULT_NUMBER=+12025550100

# ── GOOGLE CALENDAR (only needed for calendar booking) ───────────
# Get from: console.cloud.google.com → OAuth credentials
GOOGLE_CLIENT_ID=placeholder.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=placeholder_get_from_google
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ── ANTHROPIC (only needed for AI features) ──────────────────────
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-placeholder_get_from_anthropic

# ── APP URLS (local dev values) ──────────────────────────────────
API_BASE_URL=http://localhost:3000
DASHBOARD_URL=http://localhost:5173
WEBHOOK_BASE_URL=http://localhost:3000
